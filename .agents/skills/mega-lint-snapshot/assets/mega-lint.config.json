{
  "items": [
    {
      "name": "BASH",
      "command": "bash",
      "args": ["-lc", "rg --files -g '*.sh' | xargs -r shellcheck"],
      "optional": true
    },
    {
      "name": "BASH_EXEC",
      "command": "bash",
      "args": ["-lc", "rg --files -g '*.sh' | xargs -r -n1 test -x"]
    },
    {
      "name": "CHECKOV",
      "command": "bash",
      "args": ["-lc", "checkov -d ."],
      "optional": true
    },
    {
      "name": "GITLEAKS",
      "command": "bash",
      "args": ["-lc", "gitleaks detect --source . --no-git -c .gitleaks.toml"],
      "optional": true
    },
    {
      "name": "JAVASCRIPT_ES",
      "command": "pnpm",
      "args": ["run", "lint"]
    },
    {
      "name": "JAVASCRIPT_PRETTIER",
      "command": "pnpm",
      "args": ["exec", "prettier", "--check", "."],
      "fixArgs": ["exec", "prettier", "--write", "."]
    },
    {
      "name": "JSCPD",
      "command": "pnpm",
      "args": ["exec", "jscpd", "--config", ".jscpd.json", "--silent"]
    },
    {
      "name": "JSON",
      "command": "bash",
      "args": [
        "-lc",
        "rg --files -g '*.json' | xargs -r -n1 node -e \"JSON.parse(require('fs').readFileSync(process.argv[1], 'utf8'))\""
      ]
    },
    {
      "name": "JSON_PRETTIER",
      "command": "pnpm",
      "args": ["exec", "prettier", "--check", "**/*.json"],
      "fixArgs": ["exec", "prettier", "--write", "**/*.json"]
    },
    {
      "name": "MARKDOWN",
      "command": "pnpm",
      "args": [
        "exec",
        "markdownlint-cli2",
        "**/*.md",
        "!node_modules/**/*.md",
        "!dist/**/*.md",
        "!report/**/*.md",
        "!reports/**/*.md"
      ]
    },
    {
      "name": "MARKDOWN_PRETTIER",
      "command": "pnpm",
      "args": ["exec", "prettier", "--check", "**/*.md"],
      "fixArgs": ["exec", "prettier", "--write", "**/*.md"]
    },
    {
      "name": "NATURAL_LANGUAGE",
      "command": "bash",
      "args": ["-lc", "textlint \"**/*.{md,txt}\""],
      "optional": true
    },
    {
      "name": "SHELL_SHFMT",
      "command": "bash",
      "args": ["-lc", "rg -0 --files -g '*.sh' | xargs -0 -r shfmt -d"],
      "optional": true
    }
  ]
}
