{
  "extends": "./jsconfig.json",
  "compilerOptions": {
    "checkJs": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "src/context/**/*",
    "src/components/**/*",
    "src/hooks/**/*",
    "src/utils/**/*",
    "src/ui/**/*",
    "src/data/**/*",
    "src/scenes/**/*",
    "src/types/**/*.d.ts"
  ]
}
