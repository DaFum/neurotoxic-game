{
  "name": "neurotoxic-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "node ./scripts/run-tests.mjs",
    "test:node": "node --max-old-space-size=4096 ./scripts/run-node-tests.mjs",
    "test:vitest": "pnpm run test:vitest:node && pnpm run test:vitest:ui",
    "test:vitest:node": "pnpm run test:vitest:logic",
    "test:vitest:ui": "node ./scripts/run-vitest-ui.mjs",
    "test:ui": "pnpm run test:vitest:ui",
    "test:all": "pnpm run test && pnpm run test:ui && pnpm run test:vitest:logic",
    "test:additional": "pnpm run test:perf && pnpm run test:locale:smoke && pnpm run test:locale:full",
    "test:fast": "pnpm run test",
    "test:perf": "vitest run --config vitest.config.perf.js tests/performance",
    "test:locale:smoke": "node --test tests/locale/smoke.test.js",
    "test:locale:full": "node --test tests/locale/full.test.js",
    "simulate:balance": "node scripts/game-balance-simulation.mjs",
    "simulate:balance:compare": "node scripts/game-balance-simulation.mjs --compare-baseline reports/game-balance-simulation-baseline.json",
    "simulate:balance:baseline": "node scripts/game-balance-simulation.mjs --write-baseline reports/game-balance-simulation-baseline.json",
    "bench:eventEngine": "node tests/performance/eventEngine.bench.js",
    "test:e2e": "playwright test",
    "test:e2e:shard1": "playwright test --shard=1/2",
    "test:e2e:shard2": "playwright test --shard=2/2",
    "format": "prettier --write .",
    "prepare": "husky",
    "i18n:extract": "i18next --config i18next-parser.config.js",
    "test:vitest:logic": "node ./scripts/run-vitest-ui.mjs --config vitest.config.node.js",
    "typecheck": "node ./scripts/typecheck-reducers.mjs",
    "typecheck:core": "tsc -p jsconfig.checkjs.json",
    "guard:nocheck": "node ./scripts/check-ts-nocheck-budget.mjs"
  },
  "standard": {
    "env": [
      "browser"
    ]
  },
  "dependencies": {
    "@tonejs/midi": "2.0.28",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "flatted": "^3.4.2",
    "framer-motion": "12.38.0",
    "i18next": "26.0.7",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.6",
    "lucide-react": "1.9.0",
    "motion-dom": "^12.38.0",
    "motion-utils": "^12.36.0",
    "pixi.js": "8.18.1",
    "playwright": "^1.59.1",
    "prop-types": "15.8.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "^17.0.4",
    "redis": "^5.12.1",
    "tone": "15.5.6"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "4.2.3",
    "@eslint/js": "10.0.1",
    "@iarna/toml": "2.2.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "4.2.4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.6.0",
    "@types/prop-types": "^15.7.15",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "10.5.0",
    "benchmark": "^2.1.4",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.5.0",
    "husky": "^9.1.7",
    "i18next-parser": "^9.4.0",
    "jsdom": "29.0.2",
    "lint-staged": "^16.3.3",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "rollup-plugin-visualizer": "7.0.1",
    "tailwindcss": "4.2.4",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vite-plugin-compression": "0.5.1",
    "vitest": "^4.0.18",
    "yaml": "2.8.3"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
