{
  "name": "neurotoxic-game",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.2.2",
  "type": "module",
  "scripts": {
    "bench:eventEngine": "node --import tsx tests/performance/eventEngine.bench.js",
    "build": "vite build",
    "dev": "vite",
    "format": "prettier --write .",
    "guard:nocheck": "node ./scripts/check-ts-nocheck-budget.mjs",
    "i18n:extract": "i18next --config i18next-parser.config.js",
    "lint": "eslint . && pnpm run lint:css",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "lint:fix": "eslint . --fix && pnpm run lint:css:fix",
    "prepare": "husky",
    "preview": "vite preview",
    "simulate:balance": "node --import tsx scripts/game-balance-simulation.mjs",
    "simulate:balance:baseline": "node --import tsx scripts/game-balance-simulation.mjs --write-baseline reports/game-balance-simulation-baseline.json",
    "simulate:balance:compare": "node --import tsx scripts/game-balance-simulation.mjs --compare-baseline reports/game-balance-simulation-baseline.json",
    "symbols:check": "node scripts/update-symbols.mjs --check",
    "symbols:update": "node ./scripts/update-symbols.mjs",
    "test": "pnpm run test:fast",
    "test:additional": "pnpm run test:perf && pnpm run test:locale:smoke && pnpm run test:locale:full",
    "test:all": "node ./scripts/run-all-tests.mjs",
    "test:e2e": "playwright test",
    "test:e2e:shard1": "playwright test --shard=1/2",
    "test:e2e:shard2": "playwright test --shard=2/2",
    "test:fast": "node ./scripts/run-fast-tests.mjs",
    "test:locale:full": "node --test tests/locale/full.test.js",
    "test:locale:smoke": "node --test tests/locale/smoke.test.js",
    "test:node": "node --max-old-space-size=4096 ./scripts/run-node-tests.mjs",
    "test:node:heavy": "node --max-old-space-size=4096 ./scripts/run-node-tests.mjs --only-heavy",
    "test:node:quick": "node --max-old-space-size=4096 ./scripts/run-node-tests.mjs --skip-heavy",
    "test:perf": "vitest run --config vitest.config.perf.js tests/performance",
    "test:ui": "pnpm run test:vitest:ui",
    "test:ui:file": "pnpm exec vitest run",
    "test:vitest": "pnpm run test:vitest:node && pnpm run test:vitest:ui",
    "test:vitest:logic": "node ./scripts/run-vitest-ui.mjs --config vitest.config.node.js",
    "test:vitest:node": "pnpm run test:vitest:logic",
    "test:vitest:ui": "node ./scripts/run-vitest-ui.mjs",
    "typecheck": "node ./scripts/typecheck-reducers.mjs",
    "typecheck:core": "tsc -p jsconfig.checkjs.json"
  },
  "standard": {
    "env": [
      "browser"
    ]
  },
  "dependencies": {
    "@tonejs/midi": "2.0.28",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "flatted": "3.4.2",
    "framer-motion": "12.42.2",
    "i18next": "26.3.4",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-http-backend": "4.0.0",
    "lucide-react": "1.17.0",
    "motion-dom": "12.42.2",
    "motion-utils": "12.39.0",
    "pixi.js": "8.19.0",
    "playwright": "1.61.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "17.0.8",
    "redis": "5.12.1",
    "tone": "15.5.22"
  },
  "devDependencies": {
    "@dreamsicle.io/stylelint-config-tailwindcss": "1.2.2",
    "@eslint-react/eslint-plugin": "5.8.6",
    "@eslint/js": "10.0.1",
    "@iarna/toml": "2.2.5",
    "@playwright/test": "1.61.0",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "10.5.2",
    "benchmark": "2.1.4",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-tsdoc": "^0.5.2",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "i18next-parser": "9.4.0",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "rollup-plugin-visualizer": "7.0.1",
    "serialize-javascript": "7.0.7",
    "stylelint": "17.12.0",
    "stylelint-config-standard": "40.0.0",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vite-plugin-compression": "0.5.1",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.8",
    "workbox-build": "7.4.1",
    "workbox-window": "7.4.1",
    "yaml": "2.9.0"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
